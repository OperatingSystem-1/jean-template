{
  "$schema": "https://docs.clawd.bot/schema/clawdbot.json",
  "version": 1,
  "gateway": {
    "port": 3000,
    "auth": {
      "token": "your-gateway-token-here"
    }
  },
  "agents": {
    "defaults": {
      "model": "anthropic/claude-sonnet-4-20250514",
      "maxTokens": 8192,
      "systemPreamble": "Read AGENTS.md, SOUL.md, and memory/LAST_SESSION.md on session start."
    },
    "entries": {}
  },
  "models": {
    "tiers": {
      "fast": {
        "comment": "Quick tasks, low cost",
        "examples": ["anthropic/claude-haiku-3", "openai/gpt-4o-mini"]
      },
      "balanced": {
        "comment": "Most tasks",
        "examples": ["anthropic/claude-sonnet-4-20250514", "openai/gpt-4o"]
      },
      "powerful": {
        "comment": "Complex reasoning",
        "examples": ["anthropic/claude-opus-4-5-20251101", "openai/o1"]
      }
    }
  },
  "channels": {
    "comment": "Configure your messaging channels here",
    "whatsapp": {
      "enabled": false
    },
    "telegram": {
      "enabled": false
    }
  },
  "skills": {
    "searchPaths": ["./skills", "~/clawd/skills"]
  },
  "cron": {
    "jobs": [
      {
        "id": "morning-briefing",
        "schedule": "0 8 * * 1-5",
        "text": "Run morning briefing per HEARTBEAT.md",
        "enabled": false
      },
      {
        "id": "heartbeat",
        "schedule": "*/30 * * * *",
        "text": "Heartbeat check",
        "enabled": false
      }
    ]
  },
  "browser": {
    "profiles": {
      "clawd": {
        "comment": "Main automation profile"
      }
    }
  }
}
